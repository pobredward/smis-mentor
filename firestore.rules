rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // 헬퍼 함수
    // ──────────────────────────────────────────────────────────────

    // 로그인 여부
    function isAuthenticated() {
      return request.auth != null;
    }

    // 사용자 역할 가져오기 (Firestore 문서 기반)
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // 역할 체크 헬퍼
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // 활성 사용자 (temp 아님)
    function isActiveUser() {
      return isAuthenticated() && getUserRole() in ['admin', 'mentor', 'foreign'];
    }

    // 캠프 운영진 (admin + active mentor/foreign)
    function isCampStaff() {
      return isAuthenticated() && getUserRole() in ['admin', 'mentor', 'foreign'];
    }

    // 본인 여부
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 필드 변경 감지: 변경되지 않아야 할 필드
    function fieldUnchanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ──────────────────────────────────────────────────────────────
    // users 컬렉션
    // 역할: admin(전체), 본인(읽기 + 제한적 수정), 비인증(가입/로그인용 쿼리만)
    //
    // [읽기 설계 배경]
    // 로그인·가입·소셜 로그인 플로우에서 Firebase Auth 세션이 없는 상태로
    // email / phoneNumber / status 기반 where 쿼리를 수행해야 한다.
    // - 단건 직접 읽기(get)는 본인 또는 admin만 허용한다.
    // - collection list 쿼리는 미인증 사용자도 허용한다.
    //   (클라이언트 SDK에서 where 조건 없는 전체 조회는 Rules 상 거부됨)
    // ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if (
        // admin: 단건 직접 읽기 허용
        isAdmin() ||
        // 본인: 자신의 문서 단건 읽기
        isOwner(userId) ||
        // 인증된 캠프 운영진: 팀원 정보 조회 (평가·업무 등 협업 목적)
        isCampStaff()
      );

      allow list: if (
        // admin: 전체 목록 조회
        isAdmin() ||
        // 인증된 캠프 운영진: 팀원 목록 조회
        isCampStaff() ||
        // 미인증 포함 모든 사용자: 로그인·가입 플로우의 중복 확인 및 계정 조회
        // (where 조건 없는 전체 조회는 Firestore가 클라이언트 SDK 레벨에서 차단됨)
        true
      );

      // 신규 가입 시 생성
      // Case 1: temp 계정 선생성 (admin이 미리 만들어 둔 경우)
      // Case 2: 가입 완료 시 active 계정 직접 생성 (Firebase Auth UID = userId)
      allow create: if (
        // 필수 필드 존재 확인
        request.resource.data.keys().hasAll(['name', 'email', 'role', 'status', 'agreedTerms', 'agreedPersonal']) &&
        // 이름 길이 제한 (DoS 방지)
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 50 &&
        // 이메일 길이 제한
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        // 허용 역할
        request.resource.data.role in ['mentor_temp', 'foreign_temp', 'mentor', 'foreign'] &&
        // 역할에 따른 status 일관성
        // - admin이 미리 선생성한 temp 계정: *_temp + temp
        // - 가입 완료 즉시 활성화: mentor_temp/foreign/mentor + active
        //   (mentor_temp + active: 멘토는 가입 후 admin 승격 대기)
        //   (foreign + active: 원어민은 가입 즉시 활성)
        (
          (request.resource.data.role in ['mentor_temp', 'foreign_temp'] && request.resource.data.status == 'temp') ||
          (request.resource.data.role == 'mentor_temp' && request.resource.data.status == 'active') ||
          (request.resource.data.role in ['mentor', 'foreign'] && request.resource.data.status == 'active')
        )
      );

      // 수정 권한
      allow update: if (
        // admin: 모든 필드 수정 가능 (역할 변경 포함)
        isAdmin() ||
        // 본인: 일반 프로필 수정 (role/status 변경 불가, 암호화 필드 직접 쓰기 금지)
        (
          isOwner(userId) &&
          fieldUnchanged('role') &&
          fieldUnchanged('status') &&
          fieldUnchanged('deletedAt') &&
          fieldUnchanged('deletedBy') &&
          // 암호화된 주민번호 뒷자리는 클라이언트에서 직접 쓰기 금지 (API Route만 허용)
          fieldUnchanged('rrnLastEncrypted') &&
          (!('name' in request.resource.data) || request.resource.data.name.size() <= 50) &&
          (!('email' in request.resource.data) || request.resource.data.email.size() <= 200)
        ) ||
        // 본인: 회원 탈퇴 (active → inactive 전환만 허용)
        // status: active → inactive 전환 + role/email/rrnLastEncrypted/deletedAt/deletedBy 변경 불가
        // 허용 변경 필드: status, name, originalEmail, deactivatedAt, updatedAt, profileImage, foreignTeacher
        (
          isOwner(userId) &&
          resource.data.status == 'active' &&
          request.resource.data.status == 'inactive' &&
          fieldUnchanged('role') &&
          fieldUnchanged('email') &&
          fieldUnchanged('rrnLastEncrypted') &&
          fieldUnchanged('deletedAt') &&
          fieldUnchanged('deletedBy')
        ) ||
        // 가입 완료 시 temp→active 승격 (Firebase Auth UID로 인증된 상태)
        // role: *_temp → mentor/foreign, status: temp → active 변경 허용
        (
          isOwner(userId) &&
          resource.data.status == 'temp' &&
          request.resource.data.status == 'active' &&
          resource.data.role in ['mentor_temp', 'foreign_temp'] &&
          request.resource.data.role in ['mentor', 'foreign'] &&
          fieldUnchanged('deletedAt') &&
          fieldUnchanged('deletedBy') &&
          // 가입 완료 시에도 암호화 필드 직접 쓰기 금지
          fieldUnchanged('rrnLastEncrypted') &&
          (!('name' in request.resource.data) || request.resource.data.name.size() <= 50) &&
          (!('email' in request.resource.data) || request.resource.data.email.size() <= 200)
        )
      );

      // 삭제: admin 또는 가입 플로우에서 본인이 소유한 temp 문서 삭제
      // (소셜 가입 시 임시 문서를 새 UID 문서로 교체하는 과정)
      // isOwner(userId): Auth UID = 문서 ID인 경우 (temp 활성화 직후)
      // resource.data.userId == request.auth.uid: Firestore userId 필드 기준 본인 확인
      allow delete: if (
        isAdmin() ||
        (
          isAuthenticated() &&
          resource.data.status == 'temp' &&
          resource.data.role in ['mentor_temp', 'foreign_temp'] &&
          (
            isOwner(userId) ||
            resource.data.userId == request.auth.uid
          )
        )
      );
    }

    // ──────────────────────────────────────────────────────────────
    // jobCodes 컬렉션 (캠프 코드)
    // 역할: admin(전체), 인증 사용자(읽기)
    // 참고: 회원가입 단계에서 미인증 상태로 jobCode 조회가 필요하므로 전체 읽기 허용
    // ──────────────────────────────────────────────────────────────
    match /jobCodes/{jobCodeId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // jobBoards 컬렉션 (채용 공고)
    // 역할: admin(전체), 전체 공개(읽기) - 비로그인 사용자도 공고 열람 가능
    // ──────────────────────────────────────────────────────────────
    match /jobBoards/{jobBoardId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // applicationHistories 컬렉션 (지원 내역)
    // 역할: admin(전체), 본인(자신의 지원 내역 읽기/취소)
    // ──────────────────────────────────────────────────────────────
    match /applicationHistories/{applicationId} {
      allow read: if (
        isAdmin() ||
        // 본인의 지원 내역만 읽기
        (isAuthenticated() && resource.data.refUserId == request.auth.uid)
      );
      allow create: if (
        isAuthenticated() &&
        // 본인 명의로만 지원 가능
        request.resource.data.refUserId == request.auth.uid &&
        // 필수 필드
        request.resource.data.keys().hasAll(['refUserId', 'refJobBoardId', 'applicationStatus', 'createdAt', 'updatedAt']) &&
        // 최초 상태는 'pending'만 가능
        request.resource.data.applicationStatus == 'pending'
      );
      allow update: if (
        isAdmin() ||
        // 본인이 본인 지원을 'cancelled'로만 변경 가능 (pending 상태에서만)
        (
          isAuthenticated() &&
          resource.data.refUserId == request.auth.uid &&
          resource.data.applicationStatus == 'pending' &&
          request.resource.data.applicationStatus == 'cancelled' &&
          // refUserId, refJobBoardId 변경 불가
          fieldUnchanged('refUserId') &&
          fieldUnchanged('refJobBoardId')
        )
      );
      // 삭제: admin 또는 본인 (pending 상태만)
      allow delete: if (
        isAdmin() ||
        (
          isAuthenticated() &&
          resource.data.refUserId == request.auth.uid &&
          resource.data.applicationStatus == 'pending'
        )
      );
    }

    // ──────────────────────────────────────────────────────────────
    // evaluationCriteria 컬렉션 (평가 기준 템플릿)
    // 역할: admin(전체), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /evaluationCriteria/{criteriaId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // evaluations 컬렉션 (평가 데이터)
    // 역할: admin(전체), active 사용자(본인이 평가한 것 읽기/생성/삭제)
    // ──────────────────────────────────────────────────────────────
    match /evaluations/{evaluationId} {
      allow read: if (
        isAdmin() ||
        // 평가자 본인이 작성한 평가만 읽기
        (isActiveUser() && resource.data.evaluatorId == request.auth.uid)
      );
      allow create: if (
        isActiveUser() &&
        // 본인 명의로만 평가 생성
        request.resource.data.evaluatorId == request.auth.uid &&
        // 필수 필드
        request.resource.data.keys().hasAll(['refUserId', 'evaluationStage', 'criteriaTemplateId', 'evaluatorId', 'scores', 'totalScore', 'createdAt', 'updatedAt']) &&
        // 점수 범위 체크 (0~100)
        request.resource.data.totalScore is number &&
        request.resource.data.totalScore >= 0 &&
        request.resource.data.totalScore <= 100
      );
      allow update: if (
        isAdmin() ||
        // 평가자 본인만 수정 가능 (미완료 상태에서만)
        (
          isActiveUser() &&
          resource.data.evaluatorId == request.auth.uid &&
          resource.data.isFinalized == false &&
          fieldUnchanged('evaluatorId') &&
          fieldUnchanged('refUserId')
        )
      );
      // 평가자 본인도 미완료 상태 평가 삭제 가능
      allow delete: if (
        isAdmin() ||
        (
          isActiveUser() &&
          resource.data.evaluatorId == request.auth.uid &&
          resource.data.isFinalized == false
        )
      );
    }

    // ──────────────────────────────────────────────────────────────
    // reviews 컬렉션 (후기)
    // 역할: 전체 공개(읽기) - 비로그인 사용자도 후기 열람 가능, 본인(생성/수정/삭제)
    // ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (
        isActiveUser() &&
        request.resource.data.author.id == request.auth.uid &&
        request.resource.data.keys().hasAll(['title', 'content', 'author', 'createdAt', 'updatedAt']) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 10000
      );
      allow update: if (
        isAdmin() ||
        (
          isActiveUser() &&
          resource.data.author.id == request.auth.uid &&
          fieldUnchanged('author')
        )
      );
      allow delete: if isAdmin() || (isActiveUser() && resource.data.author.id == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────────
    // smsTemplates 컬렉션 (SMS 템플릿)
    // 역할: admin(전체), 캠프 스태프(읽기)
    // ──────────────────────────────────────────────────────────────
    match /smsTemplates/{templateId} {
      allow read: if isCampStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // stSheetCache 컬렉션 (ST시트 캐시 - 학생 데이터)
    // 역할: admin(전체), 캠프 스태프(읽기)
    // 주의: 민감한 학생 개인정보 포함 (주민번호 등)
    // ──────────────────────────────────────────────────────────────
    match /stSheetCache/{campCode} {
      allow read: if isCampStaff();
      // 쓰기는 서버(Cloud Functions/Admin SDK)를 통해서만 가능
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // familySTSheetCache 컬렉션 (가족 ST시트 캐시)
    // 역할: admin(전체), 캠프 스태프(읽기)
    // ──────────────────────────────────────────────────────────────
    match /familySTSheetCache/{campCode} {
      allow read: if isCampStaff();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // campTasks 컬렉션 (캠프 업무)
    // 역할: admin(전체 CRUD), 캠프 스태프(읽기 + 완료 체크)
    // 한계: Firestore 규칙에서 배열 내부 요소(completions[*].userId)까지
    //       request.auth.uid와 비교할 수 없음. 타인 완료 체크 방지는
    //       Cloud Functions의 완료 처리 API를 통해 서버 사이드에서 검증할 것.
    // ──────────────────────────────────────────────────────────────
    match /campTasks/{taskId} {
      allow read: if isCampStaff();
      allow create: if isAdmin();
      // 업무 완료/취소 처리: completions 필드만 수정 가능, 1개 단위 변경만 허용
      allow update: if (
        isAdmin() ||
        (
          isCampStaff() &&
          // 완료 처리 및 업데이트 시간 외 필드 변경 불가
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completions', 'updatedAt']) &&
          // 완료 항목 수는 정확히 1개 증가 또는 1개 감소만 허용 (본인 완료/취소)
          (
            request.resource.data.completions.size() == resource.data.completions.size() + 1 ||
            request.resource.data.completions.size() == resource.data.completions.size() - 1
          )
        )
      );
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // personalTasks 컬렉션 (개인 업무)
    // 역할: 본인(ownerId)만 전체 CRUD — admin 포함 모든 역할(temp 포함)
    //
    // [read 설계 배경]
    // getPersonalTasksByGroupId, getPersonalTasksByDate 등 컬렉션 list 쿼리에서
    // where('ownerId', '==', uid) 조건으로 본인 데이터만 필터링한다.
    // Firestore list 쿼리는 규칙에서 resource.data를 사용할 수 없으므로
    // isAuthenticated() 수준에서 허용하되, 쿼리 자체에 ownerId 필터를 강제한다.
    // (실질적인 데이터 분리는 클라이언트 쿼리의 where('ownerId', '==', uid)로 보장)
    //
    // [delete 설계 배경]
    // deletePersonalTaskGroup은 groupId 기반 쿼리 후 배치 삭제를 수행한다.
    // temp 역할 사용자도 자신의 개인 업무를 삭제할 수 있어야 하므로
    // isActiveUser() 대신 isAuthenticated()를 사용한다.
    // ──────────────────────────────────────────────────────────────
    match /personalTasks/{taskId} {
      // list 쿼리 허용 (where ownerId == uid 조건 강제는 클라이언트에서 보장)
      // getDoc 단건 조회는 resource.data.ownerId 비교로 본인만 허용
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if (
        isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['ownerId', 'campCode', 'title', 'isCompleted', 'createdAt', 'updatedAt']) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 200
      );
      allow update: if (
        isAuthenticated() &&
        resource.data.ownerId == request.auth.uid &&
        // ownerId 변경 불가
        fieldUnchanged('ownerId')
      );
      // 본인(ownerId)만 삭제 가능 — temp 역할 포함
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────
    // taskCategories 컬렉션 (업무 카테고리)
    // 역할: admin(전체), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /taskCategories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // campPages 컬렉션 (캠프 페이지)
    // 역할: admin(전체), 캠프 스태프(역할 기반 읽기 + 본인 역할 페이지 CRUD)
    // ──────────────────────────────────────────────────────────────
    match /campPages/{pageId} {
      allow read: if (
        isAdmin() ||
        // 캠프 스태프는 targetRole 기반 읽기
        isCampStaff()
      );
      allow create: if (
        isAdmin() ||
        (
          isCampStaff() &&
          request.resource.data.keys().hasAll(['jobCodeId', 'category', 'title', 'targetRole', 'content', 'order', 'createdAt', 'updatedAt']) &&
          request.resource.data.title is string &&
          request.resource.data.title.size() <= 200 &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 500000
        )
      );
      allow update: if (
        isAdmin() ||
        (
          isCampStaff() &&
          request.resource.data.title is string &&
          request.resource.data.title.size() <= 200 &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 500000 &&
          // jobCodeId, targetRole 변경 불가 (본인 캠프/역할의 페이지만 수정)
          fieldUnchanged('jobCodeId') &&
          fieldUnchanged('targetRole')
        )
      );
      allow delete: if isAdmin() || isCampStaff();
    }

    // ──────────────────────────────────────────────────────────────
    // generationResources 컬렉션 (기수별 리소스 링크)
    // 역할: admin(전체), 캠프 스태프(읽기 + 링크 추가/수정/삭제)
    // ──────────────────────────────────────────────────────────────
    match /generationResources/{jobCodeId} {
      allow read: if isCampStaff();
      // 캠프 스태프도 링크 추가/수정/삭제 가능 (링크 관리 기능)
      allow create, update: if isCampStaff();
      // 삭제는 admin만 (전체 리소스 문서 삭제 보호)
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // lessonMaterials 컬렉션 (수업 자료)
    // 역할: admin(전체), 캠프 스태프(본인 자료 CRUD)
    // 각 사용자는 자신의 userId가 일치하는 자료만 생성/수정/삭제 가능
    // ──────────────────────────────────────────────────────────────
    match /lessonMaterials/{materialId} {
      allow read: if isCampStaff();
      // admin: 모든 자료 생성/수정/삭제
      // 캠프 스태프: 본인(userId) 자료만 생성/수정/삭제
      allow create: if (
        isAdmin() ||
        (isCampStaff() && request.resource.data.userId == request.auth.uid)
      );
      allow update: if (
        isAdmin() ||
        (isCampStaff() && resource.data.userId == request.auth.uid)
      );
      allow delete: if (
        isAdmin() ||
        (isCampStaff() && resource.data.userId == request.auth.uid)
      );

      // 서브컬렉션: sections
      // 부모 lessonMaterial의 소유자이거나 admin만 CRUD 가능
      match /sections/{sectionId} {
        allow read: if isCampStaff();
        allow create, update: if (
          isAdmin() ||
          isCampStaff()
        );
        allow delete: if (
          isAdmin() ||
          isCampStaff()
        );
      }
    }

    // ──────────────────────────────────────────────────────────────
    // lessonMaterialTemplates 컬렉션 (수업 자료 템플릿)
    // 역할: admin(전체), 캠프 스태프(읽기)
    // ──────────────────────────────────────────────────────────────
    match /lessonMaterialTemplates/{templateId} {
      allow read: if isCampStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // interviewSettings 컬렉션 (면접 설정/링크)
    // 역할: admin(전체), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /interviewSettings/{settingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // appConfig 컬렉션 (앱 전역 설정)
    // 역할: admin(전체), 인증 사용자(읽기) - 버전 체크 등
    // ──────────────────────────────────────────────────────────────
    match /appConfig/{configId} {
      // 앱 버전 체크는 미인증 상태에서도 필요할 수 있음
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // campHomeMessages 컬렉션 (캠프별 홈 메시지)
    // 역할: admin(전체), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /campHomeMessages/{campCode} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // campSettings 컬렉션 (캠프별 설정)
    // 역할: admin(전체 CRUD), 캠프 스태프(읽기)
    // 용도: 임시데이터 on/off 설정 (useTemporaryData)
    // ──────────────────────────────────────────────────────────────
    match /campSettings/{campCode} {
      allow read: if isCampStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // interviewDates 컬렉션 (면접 일정별 녹화 URL 등)
    // 역할: admin(전체 CRUD), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /interviewDates/{dateId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // interviewScripts 컬렉션 (면접 진행자 스크립트)
    // 역할: admin(전체 CRUD), 인증 사용자(읽기)
    // ──────────────────────────────────────────────────────────────
    match /interviewScripts/{scriptId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // userEvaluationSummaries 컬렉션 (사용자별 평가 요약)
    // 역할: admin(전체 CRUD)
    // 평가 생성/삭제 시 EvaluationService가 자동으로 upsert/delete
    // ──────────────────────────────────────────────────────────────
    match /userEvaluationSummaries/{userId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // userLocations 컬렉션 (실시간 위치 공유)
    // 역할: 캠프 스태프끼리 실시간 위치 공유 (토글 ON 시)
    // 문서 ID: {campCode}_{userId} 복합 키
    // ──────────────────────────────────────────────────────────────
    match /userLocations/{locationId} {
      // 로그인한 모든 사용자(temp 포함) 읽기 가능
      allow read: if isAuthenticated();
      // 본인 문서만 생성/수정 가능
      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isSharing is bool
        && request.resource.data.lat is number
        && request.resource.data.lng is number;
      // 본인 문서만 삭제 가능
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────
    // shareTokens 컬렉션 (지원자 공유 토큰)
    // 역할: 클라이언트 직접 접근 금지 (서버/Admin SDK 전용)
    // 주의: cleanup-expired API route는 반드시 Admin SDK를 사용해야 함
    //       (client SDK로 접근 시 이 규칙에 의해 Permission Denied 발생)
    // ──────────────────────────────────────────────────────────────
    match /shareTokens/{tokenId} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // auditLogs 컬렉션 (감사 로그)
    // 역할: admin(읽기), 쓰기는 서버 전용
    // ──────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // posts 컬렉션 (게시판)
    //
    // [접근 설계]
    // - 작성/읽기 권한: active 역할(mentor, foreign, admin)만 허용
    //   temp 역할(mentor_temp, foreign_temp)은 업무코드 없이 게시판 불가
    // - scope='dev': 작성자 본인 + admin만 읽기 가능
    // - scope 나머지(all/camp/group): active 캠프 스태프 전체 읽기
    //   (camp/group 범위 필터링은 클라이언트 쿼리에서 jobCodeId/groupId로 처리)
    //
    // [update 분리 설계]
    // - 좋아요 토글(likedBy, likeCount): 본인이 아닌 active 유저도 가능
    // - commentCount 증감: 댓글 생성/삭제 시 서비스에서 처리 → active 유저 허용
    // - 내용 수정(content, imageUrls): 작성자 본인 + 핵심 필드 불변 보장
    // ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // dev 게시글: 본인 또는 admin만 읽기
      // 나머지 scope: active 캠프 스태프 전체 읽기
      allow read: if (
        isActiveUser() && (
          resource.data.scope != 'dev' ||
          isAdmin() ||
          resource.data.authorId == request.auth.uid
        )
      );

      // 새 게시글 작성: active 캠프 스태프 + 본인 명의
      allow create: if (
        isActiveUser() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'scope', 'authorId', 'authorName',
          'content', 'imageUrls',
          'likeCount', 'likedBy', 'commentCount',
          'createdAt', 'updatedAt'
        ]) &&
        request.resource.data.scope in ['all', 'camp', 'group', 'dev'] &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 5000 &&
        request.resource.data.likeCount == 0 &&
        request.resource.data.commentCount == 0
      );

      // 좋아요 토글 또는 commentCount 증감:
      // active 유저라면 likedBy/likeCount/commentCount/updatedAt 만 변경 허용
      allow update: if (
        isActiveUser() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likedBy', 'likeCount', 'commentCount', 'updatedAt'])
      );

      // 게시글 내용 수정: 작성자 본인만, 핵심 필드 불변
      allow update: if (
        isActiveUser() &&
        resource.data.authorId == request.auth.uid &&
        fieldUnchanged('authorId') &&
        fieldUnchanged('scope') &&
        fieldUnchanged('jobCodeId') &&
        fieldUnchanged('groupId') &&
        fieldUnchanged('likedBy') &&
        fieldUnchanged('likeCount') &&
        fieldUnchanged('commentCount') &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 5000
      );

      // 게시글 삭제: 작성자 본인 또는 admin
      allow delete: if (
        isAdmin() ||
        (isActiveUser() && resource.data.authorId == request.auth.uid)
      );

      // 댓글 서브컬렉션
      match /comments/{commentId} {
        // dev 게시글 댓글: 본인 또는 admin만
        // 나머지: active 캠프 스태프 전체
        allow read: if (
          isActiveUser() && (
            get(/databases/$(database)/documents/posts/$(postId)).data.scope != 'dev' ||
            isAdmin() ||
            resource.data.authorId == request.auth.uid
          )
        );

        allow create: if (
          isActiveUser() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.keys().hasAll([
            'parentId', 'authorId', 'authorName',
            'content', 'createdAt', 'updatedAt'
          ]) &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 1000
        );

        // 댓글 수정 / soft delete: 작성자 본인만, 핵심 필드 불변
        allow update: if (
          isActiveUser() &&
          resource.data.authorId == request.auth.uid &&
          fieldUnchanged('authorId') &&
          fieldUnchanged('parentId')
        );

        // 댓글 삭제: 작성자 본인 또는 admin
        allow delete: if (
          isAdmin() ||
          (isActiveUser() && resource.data.authorId == request.auth.uid)
        );
      }
    }

    // ──────────────────────────────────────────────────────────────
    // 기본 거부 (명시되지 않은 모든 컬렉션)
    // ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
