{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "target": "es2020",
    "moduleResolution": "node",
    "lib": ["es2020"],
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
