    "submit:android": "eas submit --platform android --latest",
    "deploy:ios": "bash scripts/deploy.sh ios",
    "deploy:android": "bash scripts/deploy.sh android",
    "deploy:all": "bash scripts/deploy.sh all",
    "deploy:build-only:ios": "bash scripts/deploy.sh build-only-ios",
