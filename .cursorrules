## 📨 외부 연동 패턴

### SMS 템플릿 변수 치환
```typescript
// ✅ 변수 검증
function replaceSMSVariables(
  template: string,
  variables: Record<string, string>
): string {
  const variablePattern = /\{([^}]+)\}/g;
  const requiredVars = new Set<string>();
  
  let match;
  while ((match = variablePattern.exec(template)) !== null) {
    requiredVars.add(match[1]);
  }
  
  const missingVars = Array.from(requiredVars).filter(v => !(v in variables));
  
  if (missingVars.length > 0) {
    throw new Error(`Missing SMS variables: ${missingVars.join(', ')}`);
  }
  
  return template.replace(variablePattern, (_, varName) => variables[varName]);
}
```

### 에러 처리 + 재시도
```typescript
// ✅ 재시도 로직
async function sendSMS(phone: string, message: string, retries = 3) {
  for (let attempt = 0; attempt < retries; attempt++) {
    try {
      const response = await fetch(SMS_API_URL, { ... });
      if (!response.ok) throw new Error(`API error: ${response.statusText}`);
      return await response.json();
    } catch (error) {
      console.error(`SMS attempt ${attempt + 1} failed:`, error);
      if (attempt < retries - 1) {
        await sleep(1000 * (attempt + 1));  // 지수 백오프
      }
    }
  }
  throw new Error(`SMS failed after ${retries} attempts`);
}
```

