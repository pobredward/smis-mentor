{
  "extends": ["expo/tsconfig.base", "../../tsconfig.json"],
  "compilerOptions": {
    "jsx": "react-native",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@smis-mentor/shared": [
        "../shared/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    "../shared/src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
