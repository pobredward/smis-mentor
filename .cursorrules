## 🔥 Firebase 패턴

### 권한 체크
```typescript
// ✅ 역할 기반 쿼리
if (isAdmin(currentUser)) {
  // Admin: 모든 사용자 조회 (멘토, 원어민)
  usersSnapshot = await getDocs(collection(db, 'users'));
} else if (isMentor(currentUser) || isForeign(currentUser)) {
  // 멘토/원어민: 본인이 담당하는 캠프 학생만 조회 (ST시트)
  const students = await getStudentsByMentor(currentUser.name);
}
```

### 실시간 구독 cleanup
```typescript
// ✅ cleanup 구현
useEffect(() => {
  const unsubscribe = onSnapshot(
    query(collection(db, 'users'), where('role', '==', 'mentor')),
    (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setUsers(data);
    },
    (error) => {
      console.error('Subscription error:', error);
    }
  );
  
  return () => unsubscribe();
}, []);
```

### Timestamp 처리
```typescript
// ✅ Timestamp 직렬화 (Server Component props)
const serializeUser = (user: UserDocument) => ({
  ...user,
  createdAt: user.createdAt.toDate().toISOString(),
});
```

