{
  "name": "smis-mentor-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "functions"
  ],
  "overrides": {
    "react": "19.1.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:functions": "npm run serve --workspace=functions",
    "start:mobile": "npm run start --workspace=packages/mobile",
    "build:web": "npm run build --workspace=packages/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:functions": "npm run build --workspace=functions",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:web": "npm run deploy --workspace=packages/web",
    "lint": "npm run lint --workspaces",
    "clean": "rm -rf node_modules packages/*/node_modules functions/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
