  "scripts": {
    "start": "CI=false expo start",
    "start:go": "CI=false expo start --go",
    "start:clear": "bash scripts/clear-cache-and-start.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
