{
  "name": "smis-mentor-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "functions"
  ],
  "overrides": {
    "react": "19.1.0",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "dev:setup": "npm run build:shared",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:functions": "npm run serve --workspace=functions",
    "start:mobile": "npm run start --workspace=packages/mobile",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:web": "npm run build:shared && npm run build --workspace=packages/web",
    "build:functions": "npm run build:shared && npm run build --workspace=functions",
    "build:all": "npm run build:shared && npm run build:parallel",
    "build:parallel": "npm-run-all -p build:web:only build:functions:only",
    "build:web:only": "npm run build --workspace=packages/web",
    "build:functions:only": "npm run build --workspace=functions",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:web": "npm run deploy --workspace=packages/web",
    "build:mobile:dev:ios": "npm run build:dev:ios --workspace=packages/mobile",
    "build:mobile:dev:android": "npm run build:dev:android --workspace=packages/mobile",
    "build:mobile:preview:ios": "npm run build:preview:ios --workspace=packages/mobile",
    "build:mobile:preview:android": "npm run build:preview:android --workspace=packages/mobile",
    "build:mobile:prod:ios": "npm run build:prod:ios --workspace=packages/mobile",
    "build:mobile:prod:android": "npm run build:prod:android --workspace=packages/mobile",
    "build:mobile:prod:all": "npm run build:prod:all --workspace=packages/mobile",
    "submit:mobile:ios": "npm run submit:ios --workspace=packages/mobile",
    "submit:mobile:android": "npm run submit:android --workspace=packages/mobile",
    "deploy:mobile:ios": "npm run deploy:ios --workspace=packages/mobile",
    "deploy:mobile:android": "npm run deploy:android --workspace=packages/mobile",
    "deploy:mobile:all": "npm run deploy:all --workspace=packages/mobile",
    "migrate:user-roles": "ts-node --esm scripts/migrate-user-roles.ts",
    "migrate:user-id-field": "ts-node --esm scripts/migrate-user-id-field.ts",
    "migrate:user-id-field:dry-run": "ts-node --esm scripts/migrate-user-id-field.ts --dry-run",
    "migrate:auth-providers": "ts-node --esm scripts/migrate-auth-providers.ts",
    "migrate:auth-providers:dry-run": "ts-node --esm scripts/migrate-auth-providers.ts --dry-run",
    "migrate:normalize-provider-ids": "ts-node --esm scripts/migrate-normalize-provider-ids.ts",
    "migrate:normalize-provider-ids:dry-run": "ts-node --esm scripts/migrate-normalize-provider-ids.ts --dry-run",
    "check:user": "ts-node --esm scripts/check-user-auth-providers.ts",
    "fix:user-provider": "ts-node --esm scripts/fix-user-provider-id.ts",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "validate:monorepo": "node .cursor/scripts/validate-monorepo.js",
    "clean": "rm -rf node_modules packages/*/node_modules functions/node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "eslint": "^9.0.0",
    "firebase-admin": "^13.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
